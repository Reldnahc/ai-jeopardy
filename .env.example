# Required runtime values
DATABASE_URL=
OPENAI_API_KEY=
JWT_SECRET=
NODE_ENV=development

# Optional provider credentials
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
GEMINI_API_KEY=
GEMINI_BASE_URL=

# Optional local service endpoints
KOKORO_URL=http://localhost:8001
WHISPER_URL=http://localhost:8002

# Optional external APIs
BRAVE_API_KEY=

# Optional server config
PORT=3002
CORS_ORIGINS=http://localhost:5173,https://ai-jeopardy.com

# Optional model overrides
# Set this to an available provider in your environment.
DEFAULT_GENERATION_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini
STT_MODEL=gpt-4o-mini-transcribe
IMAGE_JUDGE_MODEL=gpt-4.1-mini
COTD_MODEL=gpt-4o-mini
CATEGORY_POOL_MODEL=gpt-4o-mini

# Optional gameplay tuning
BUZZ_LOCKOUT_MS=1
CLUE_ANSWER_TIMEOUT_MS=10000
FINAL_DRAW_SECONDS=30
FINAL_WAGER_SECONDS=30

# Frontend development only
VITE_API_BASE=http://localhost:3002

# docker-compose.yml only
DATABASE_PASSWORD=
